# Copy this file to .env and fill in the values

# Database
POSTGRES_DB=ghostedbyhr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Backend
DB_HOST=db
DB_PORT=5432
BACKEND_PORT=5000
JWT_SECRET=changeme

# Proxy
PROXY_PORT=80

# SMTP (leave blank to disable email sending)
# Supports any SMTP provider: Gmail, Outlook, Mailgun, SendGrid, self-hosted, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Ghosted By HR <noreply@example.com>
